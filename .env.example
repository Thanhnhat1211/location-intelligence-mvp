# ── Data Storage ──────────────────────────────────────────────
# Directory for JSON data files (analyses, comps).
# On Render, set this to the persistent disk mount path (e.g. /var/data/location-intel).
# Defaults to ./data in the project root for local development.
# DATA_DIR=

# ── OpenAI (optional) ────────────────────────────────────────
# Enables AI-enhanced strategy memos. App works fully without it.
# OPENAI_API_KEY=

# ── App Metadata ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Location Intelligence MVP
NEXT_PUBLIC_APP_VERSION=0.1.0
